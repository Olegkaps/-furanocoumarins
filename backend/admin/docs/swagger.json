    "info": {
        "contact": {},
        "description": "API for Furocoumarins admin backend",
        "title": "Furocoumarins Admin API",
        "version": "1.0"
    },
    "paths": {
        "/article/{id}": {
            "get": {
                "description": "Returns bibtex text for the given article ID",
                "parameters": [
                    {
                        "description": "Article ID",
                        "example": "key2024",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.ArticleValResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "summary": "Get article by ID",
                "tags": [
                    "bibtex"
                ]
            }
        },
        "/auth/change-password": {
            "post": {
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "description": "Sends password reset link to user email",
                "parameters": [
                    {
                        "description": "Username or email",
                        "example": "admin@example.com",
                        "in": "formData",
                        "name": "uname_or_email",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "summary": "Request password change",
                "tags": [
                    "auth"
                ]
            }
        },
        "/auth/confirm-login-mail": {
            "post": {
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "description": "Exchanges word from email link for JWT token",
                "parameters": [
                    {
                        "description": "Token from email link",
                        "example": "linAbCdEf123",
                        "in": "formData",
                        "name": "word",
                        "required": true,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.TokenResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "summary": "Confirm login via magic link",
                "tags": [
                    "auth"
                ]
            }
        },
        "/auth/confirm-password-change": {
            "post": {
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "description": "Sets new password using token from email link",
                "parameters": [
                    {
                        "description": "Token from email link",
                        "example": "pswXyZ987",
                        "in": "formData",
                        "name": "word",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "description": "New password",
                        "example": "new-secret",
                        "in": "formData",
                        "name": "password",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "summary": "Confirm password change",
                "tags": [
                    "auth"
                ]
            }
        },
        "/auth/login": {
            "post": {
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "description": "Returns JWT token on success",
                "parameters": [
                    {
                        "description": "Username or email",
                        "example": "admin@example.com",
                        "in": "formData",
                        "name": "uname_or_email",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "description": "Password",
                        "example": "secret",
                        "in": "formData",
                        "name": "password",
                        "required": true,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.TokenResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "summary": "Login with username/email and password",
                "tags": [
                    "auth"
                ]
            }
        },
        "/auth/login-mail": {
            "post": {
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "description": "Sends a magic link to user email for passwordless login",
                "parameters": [
                    {
                        "description": "Username or email",
                        "example": "admin@example.com",
                        "in": "formData",
                        "name": "uname_or_email",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "summary": "Request login link by email",
                "tags": [
                    "auth"
                ]
            }
        },
        "/auth/renew-token": {
            "post": {
                "description": "Returns new JWT token for authenticated user",
                "produces": [
                    "application/json"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.TokenResponse"
                        }
