                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "summary": "Renew JWT token",
                "tags": [
                    "auth"
                ]
            }
        },
        "/autocomplete/{column}": {
            "get": {
                "description": "Returns prefix-matched values for a column",
                "parameters": [
                    {
                        "description": "Column name",
                        "example": "species",
                        "in": "path",
                        "name": "column",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "description": "Prefix to match",
                        "example": "Angel",
                        "in": "query",
                        "name": "value",
                        "required": true,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json"
