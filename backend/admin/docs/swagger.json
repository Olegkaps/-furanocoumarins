        "/bibtex": {
            "put": {
                "consumes": [
                    "multipart/form-data"
                ],
                "description": "Uploads bibtex file and updates Cassandra",
                "parameters": [
                    {
                        "description": "Bibtex file",
                        "in": "formData",
                        "name": "file",
                        "required": true,
                        "type": "file"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Bad Request",
