                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "summary": "Get list of all tables",
                "tags": [
                    "tables"
                ]
            }
        },
        "/make-table-active/{timestamp}": {
            "post": {
                "description": "Sets the given table as the active one",
                "parameters": [
                    {
                        "description": "Table timestamp",
                        "example": "2026-01-15T12:00:00.000Z",
                        "in": "path",
                        "name": "timestamp",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Bad Request",
