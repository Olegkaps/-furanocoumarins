                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "summary": "Activate table by timestamp",
                "tags": [
                    "tables"
                ]
            }
        },
        "/metadata": {
            "get": {
                "description": "Returns metadata and timestamp of the active table",
                "produces": [
                    "application/json"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/admin_internal_presentation_http_search.MetadataResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
