                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "summary": "Update bibtex file",
                "tags": [
                    "bibtex"
                ]
            }
        },
        "/create-table": {
            "post": {
                "consumes": [
                    "multipart/form-data"
                ],
                "description": "Uploads Excel file and creates a new table",
                "parameters": [
                    {
                        "description": "Excel file",
                        "in": "formData",
                        "name": "file",
                        "required": true,
                        "type": "file"
                    },
                    {
                        "description": "Meta sheet name",
                        "example": "meta",
                        "in": "formData",
                        "name": "meta",
                        "type": "string"
                    },
                    {
                        "description": "Table name",
                        "example": "furanocoumarins_v2",
                        "in": "formData",
                        "name": "name",
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorResponse"
                        }
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "summary": "Create table from Excel file",
                "tags": [
                    "tables"
                ]
            }
        },
        "/get-tables-list": {
            "post": {
                "description": "Returns all tables from Cassandra",
